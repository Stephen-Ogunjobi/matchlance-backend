PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# MongoDB
MONGODB_URL=mongodb+srv://<user>:<password>@<host>/<db>
TEST_MONGODB_URL=mongodb://localhost:27017/matchlance-test

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Sessions
SESSION_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Matchlance

# Email redirect URLs
FRONTEND_VERIFY_URL=http://localhost:5173/verify-email
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/new-password
FRONTEND_PROPOSAL_URL=http://localhost:5173/new-proposal
FRONTEND_PROJECT_URL=http://localhost:5173/projects
FRONTEND_CONTRACT_URL=http://localhost:5173/contracts

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=
